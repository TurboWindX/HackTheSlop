# =============================================================================
# Scenario: ACL Abuse
# VMs: DC01 + WS01   |  RAM: ~6 GB   |  Provision time: ~25 min
#
# Attack techniques covered:
#   GenericAll          â€” carol.white â†’ svc_sql (reset pass, set SPN, more)
#   ForceChangePassword â€” helpdesk â†’ alice.jones, bob.smith
#   DCSync              â€” bob.smith (DS-Replication-Get-Changes*)
#                         secretsdump.py 'LAB/bob.smith:Password123!@192.168.56.10'
#   AdminSDHolder       â€” carol.white GenericAll on AdminSDHolder container
#                         After SDProp (~60 min): control all DA-protected objects
#   WriteDACL (via DC)  â€” escalate to WriteDACL on domain root â†’ grant DCSync
#   GPO abuse           â€” carol.white (IT Admins) GenericWrite on LabSecurityPolicy
#                         Linked to OU=Corp â†’ code exec on all joined machines
#   RBCD                â€” SRV01$ has msDS-AllowedToActOnBehalfOfOtherIdentity on WS01
#                         Relay/coerce â†’ RBCD â†’ impersonate DA to CIFS/WS01
#   AddMember (via GenericAll) â€” carol.white resets svc_sql â†’ adds to DA group
#
# Usage:
#   From this directory:  vagrant up
#   Tear down:            vagrant destroy -f
# =============================================================================

VAGRANTFILE_API_VERSION = "2"

DOMAIN       = "turbo.lab"
DOMAIN_SHORT = "TURBOLAB"
DOMAIN_PASS  = "vagrant"
DC_IP        = "192.168.56.10"
WS1_IP       = "192.168.56.30"

Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|
  config.vm.box_check_update   = false
  config.winrm.transport       = :negotiate
  config.winrm.basic_auth_only = false
  config.vm.boot_timeout        = 1200
  config.winrm.timeout          = 7200
  config.winrm.retry_limit      = 60
  config.winrm.retry_delay      = 10

  # â”€â”€ DC01: Domain Controller â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  config.vm.define "dc01", primary: true do |dc|
    dc.vm.box      = "StefanScherer/windows_2019"
    dc.vm.network  "private_network", ip: DC_IP
    dc.vm.synced_folder ".", "/vagrant", disabled: true

    dc.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "ACL-DC01"
      v.memory = 4096
      v.cpus   = 2
    end

    dc.vm.provider "virtualbox" do |vb|
      vb.name   = "ACL-DC01"
      vb.memory = 4096
      vb.cpus   = 2
      vb.customize ["modifyvm", :id, "--nicpromisc2", "allow-all"]
    end

    dc.vm.provision "file",
      source:      "../../scripts/provision-dc01-step2.ps1",
      destination: "C:/Windows/Temp/provision-dc01-step2.ps1"

    dc.vm.provision "shell",
      path:   "../../scripts/provision-dc01-bootstrap.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
      }
  end

  # â”€â”€ WS01: Domain workstation â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  config.vm.define "ws01" do |ws|
    ws.vm.box      = "StefanScherer/windows_10"
    ws.vm.network  "private_network", ip: WS1_IP

    ws.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "ACL-WS01"
      v.memory = 2048
      v.cpus   = 2
    end

    ws.vm.provider "virtualbox" do |vb|
      vb.name   = "ACL-WS01"
      vb.memory = 2048
      vb.cpus   = 2
    end

    ws.vm.provision "shell",
      path: "../../scripts/provision-ws01.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
        "WS_IP"        => WS1_IP,
      }
  end
end
