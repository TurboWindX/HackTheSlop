# =============================================================================
# Scenario: Lateral Movement
# VMs: DC01 + SRV01 + WS01   |  RAM: ~9 GB   |  Provision time: ~45 min
#
# Attack techniques covered:
#   Pass-the-Hash (PTH)     — wmiexec, smbexec, psexec via NT hash
#   Pass-the-Ticket (PTT)   — inject TGT/TGS, move between hosts
#   Evil-WinRM              — WinRM on WS01 port 5985 / SRV01
#   DCOM lateral            — MMC20.Application / ShellWindows
#   WMI exec                — Invoke-WmiMethod Win32_Process
#   Remote Scheduled Tasks  — schtasks /s (no hash needed if on same domain)
#   Remote Service          — sc \\target create + start
#   MSSQL linked chains     — xp_cmdshell on SRV01 → OS commands as SQL svc
#   DPAPI credential theft  — WS01 vault: LAB\svc_backup + LAB\carol.white
#   AutoLogon creds         — WS01 registry: LAB\bob.smith plaintext
#   Token impersonation     — Incognito / potato attacks post-admin
#   Creds in shares         — \\SRV01\IT\it-creds.txt
#
# Cred chain example:
#   1. Spray → get alice.jones (weak pass)
#   2. From alice → read \\SRV01\IT share → sa_lab / Lab12345
#   3. SA_lab xp_cmdshell → SYSTEM on SRV01
#   4. PTH SRV01$ → WS01 WinRM (RBCD or local admin)
#   5. WS01 DPAPI → carol.white hash → GenericAll → full DA
#
# Usage:
#   From this directory:  vagrant up
#   Tear down:            vagrant destroy -f
# =============================================================================

VAGRANTFILE_API_VERSION = "2"

DOMAIN       = "lab.local"
DOMAIN_SHORT = "LAB"
DOMAIN_PASS  = "Vagrant123!"
DC_IP        = "192.168.56.10"
SRV_IP       = "192.168.56.20"
WS1_IP       = "192.168.56.30"

Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|
  config.vm.box_check_update   = false
  config.winrm.transport       = :negotiate
  config.winrm.basic_auth_only = false

  # ── DC01: Domain Controller ──────────────────────────────────────────────────
  config.vm.define "dc01", primary: true do |dc|
    dc.vm.box      = "StefanScherer/windows_2019"
    dc.vm.hostname = "DC01"
    dc.vm.network  "private_network", ip: DC_IP, virtualbox__intnet: "lab-net"

    dc.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "LAT-DC01"
      v.memory = 4096
      v.cpus   = 2
    end

    dc.vm.provider "virtualbox" do |vb|
      vb.name   = "LAT-DC01"
      vb.memory = 4096
      vb.cpus   = 2
      vb.customize ["modifyvm", :id, "--nicpromisc2", "allow-all"]
    end

    dc.vm.provision "shell",
      path:   "../../scripts/provision-dc01-step1.ps1",
      reboot: true,
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
      }

    dc.vm.provision "shell",
      path: "../../scripts/provision-dc01-step2.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
      }
  end

  # ── SRV01: Member server (SQL + IIS + share) ─────────────────────────────────
  config.vm.define "srv01" do |srv|
    srv.vm.box      = "StefanScherer/windows_2019"
    srv.vm.hostname = "SRV01"
    srv.vm.network  "private_network", ip: SRV_IP, virtualbox__intnet: "lab-net"

    srv.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "LAT-SRV01"
      v.memory = 3072
      v.cpus   = 2
    end

    srv.vm.provider "virtualbox" do |vb|
      vb.name   = "LAT-SRV01"
      vb.memory = 3072
      vb.cpus   = 2
    end

    srv.vm.provision "shell",
      path: "../../scripts/provision-srv01.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
        "SRV_IP"       => SRV_IP,
      }
  end

  # ── WS01: Domain workstation (DPAPI vault, AutoLogon) ────────────────────────
  config.vm.define "ws01" do |ws|
    ws.vm.box      = "StefanScherer/windows_10"
    ws.vm.hostname = "WS01"
    ws.vm.network  "private_network", ip: WS1_IP, virtualbox__intnet: "lab-net"

    ws.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "LAT-WS01"
      v.memory = 2048
      v.cpus   = 2
    end

    ws.vm.provider "virtualbox" do |vb|
      vb.name   = "LAT-WS01"
      vb.memory = 2048
      vb.cpus   = 2
    end

    ws.vm.provision "shell",
      path: "../../scripts/provision-ws01.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
        "WS_IP"        => WS1_IP,
      }
  end
end
