# =============================================================================
# Scenario: Lateral Movement
# VMs: DC01 + SRV01 + WS01   |  RAM: ~9 GB   |  Provision time: ~45 min
#
# Attack techniques covered:
#   Pass-the-Hash (PTH)     â€” wmiexec, smbexec, psexec via NT hash
#   Pass-the-Ticket (PTT)   â€” inject TGT/TGS, move between hosts
#   Evil-WinRM              â€” WinRM on WS01 port 5985 / SRV01
#   DCOM lateral            â€” MMC20.Application / ShellWindows
#   WMI exec                â€” Invoke-WmiMethod Win32_Process
#   Remote Scheduled Tasks  â€” schtasks /s (no hash needed if on same domain)
#   Remote Service          â€” sc \\target create + start
#   MSSQL linked chains     â€” xp_cmdshell on SRV01 â†’ OS commands as SQL svc
#   DPAPI credential theft  â€” WS01 vault: LAB\svc_backup + LAB\carol.white
#   AutoLogon creds         â€” WS01 registry: LAB\bob.smith plaintext
#   Token impersonation     â€” Incognito / potato attacks post-admin
#   Creds in shares         â€” \\SRV01\IT\it-creds.txt
#
# Cred chain example:
#   1. Spray â†’ get alice.jones (weak pass)
#   2. From alice â†’ read \\SRV01\IT share â†’ sa_lab / Lab12345
#   3. SA_lab xp_cmdshell â†’ SYSTEM on SRV01
#   4. PTH SRV01$ â†’ WS01 WinRM (RBCD or local admin)
#   5. WS01 DPAPI â†’ carol.white hash â†’ GenericAll â†’ full DA
#
# Usage:
#   From this directory:  vagrant up
#   Tear down:            vagrant destroy -f
# =============================================================================

VAGRANTFILE_API_VERSION = "2"

DOMAIN       = "turbo.lab"
DOMAIN_SHORT = "TURBOLAB"
DOMAIN_PASS  = "vagrant"
DC_IP        = "192.168.56.10"
SRV_IP       = "192.168.56.20"
WS1_IP       = "192.168.56.30"

Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|
  config.vm.box_check_update   = false
  config.winrm.transport       = :negotiate
  config.winrm.basic_auth_only = false
  config.vm.boot_timeout        = 1200
  config.winrm.timeout          = 7200
  config.winrm.retry_limit      = 60
  config.winrm.retry_delay      = 10

  # â”€â”€ DC01: Domain Controller â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  config.vm.define "dc01", primary: true do |dc|
    dc.vm.box      = "StefanScherer/windows_2019"
    dc.vm.network  "private_network", ip: DC_IP
    dc.vm.synced_folder ".", "/vagrant", disabled: true

    dc.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "LAT-DC01"
      v.memory = 4096
      v.cpus   = 2
    end

    dc.vm.provider "virtualbox" do |vb|
      vb.name   = "LAT-DC01"
      vb.memory = 4096
      vb.cpus   = 2
      vb.customize ["modifyvm", :id, "--nicpromisc2", "allow-all"]
    end

    dc.vm.provision "file",
      source:      "../../scripts/provision-dc01-step2.ps1",
      destination: "C:/Windows/Temp/provision-dc01-step2.ps1"

    dc.vm.provision "shell",
      path:   "../../scripts/provision-dc01-bootstrap.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
      }
  end

  # â”€â”€ SRV01: Member server (SQL + IIS + share) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  config.vm.define "srv01" do |srv|
    srv.vm.box      = "StefanScherer/windows_2019"
    srv.vm.network  "private_network", ip: SRV_IP

    srv.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "LAT-SRV01"
      v.memory = 3072
      v.cpus   = 2
    end

    srv.vm.provider "virtualbox" do |vb|
      vb.name   = "LAT-SRV01"
      vb.memory = 3072
      vb.cpus   = 2
    end

    srv.vm.provision "shell",
      path: "../../scripts/provision-srv01.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
        "SRV_IP"       => SRV_IP,
      }
  end

  # â”€â”€ WS01: Domain workstation (DPAPI vault, AutoLogon) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  config.vm.define "ws01" do |ws|
    ws.vm.box      = "StefanScherer/windows_10"
    ws.vm.network  "private_network", ip: WS1_IP

    ws.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "LAT-WS01"
      v.memory = 2048
      v.cpus   = 2
    end

    ws.vm.provider "virtualbox" do |vb|
      vb.name   = "LAT-WS01"
      vb.memory = 2048
      vb.cpus   = 2
    end

    ws.vm.provision "shell",
      path: "../../scripts/provision-ws01.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
        "WS_IP"        => WS1_IP,
      }
  end
end
