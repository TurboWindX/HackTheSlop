# =============================================================================
# Scenario: ADCS Deep Dive
# VMs: DC01 + WS01   |  RAM: ~6 GB   |  Provision time: ~30 min
#
# Attack techniques covered:
#   ESC1   — VulnTemplate: ENROLLEE_SUPPLIES_SUBJECT, Domain Users enroll
#            certipy req -ca LAB-CA -template VulnTemplate -upn administrator@turbo.lab
#   ESC2   — AnyPurposeTemplate: no EKU restriction, Domain Users enroll
#            Can be used as sub-CA or for any extended purpose
#   ESC3   — EnrollmentAgentTemplate: request certs on behalf of any principal
#            Step 1: get enrollment agent cert  Step 2: request cert for Administrator
#   ESC4   — WritableCertTemplate: Domain Users have GenericWrite on template
#            Modify template to add ENROLLEE_SUPPLIES_SUBJECT → becomes ESC1
#   ESC6   — EDITF_ATTRIBUTESUBJECTALTNAME2 on CA: all templates accept attacker SAN
#   ESC8   — Web Enrollment NTLM relay: ntlmrelayx -t http://DC01/certsrv/certfnsh.asp
#   Cert Theft — Exporting certs with private keys via CryptoAPI / CAPI2 / certutil
#   PKINIT — Use certificate to get TGT (certipy auth / Rubeus asktgt)
#
# Usage:
#   From this directory:  vagrant up
#   Tear down:            vagrant destroy -f
# =============================================================================

VAGRANTFILE_API_VERSION = "2"

DOMAIN       = "turbo.lab"
DOMAIN_SHORT = "TURBO"
DOMAIN_PASS  = "Vagrant123!"
DC_IP        = "192.168.56.10"
WS1_IP       = "192.168.56.30"

Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|
  config.vm.box_check_update   = false
  config.winrm.transport       = :negotiate
  config.winrm.basic_auth_only = false

  # ── DC01: Domain Controller + ADCS CA ────────────────────────────────────────
  config.vm.define "dc01", primary: true do |dc|
    dc.vm.box      = "StefanScherer/windows_2019"
    dc.vm.hostname = "DC01"
    dc.vm.network  "private_network", ip: DC_IP, virtualbox__intnet: "lab-net"

    dc.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "ADCS-DC01"
      v.memory = 4096
      v.cpus   = 2
    end

    dc.vm.provider "virtualbox" do |vb|
      vb.name   = "ADCS-DC01"
      vb.memory = 4096
      vb.cpus   = 2
      vb.customize ["modifyvm", :id, "--nicpromisc2", "allow-all"]
    end

    dc.vm.provision "shell",
      path:   "../../scripts/provision-dc01-step1.ps1",
      reboot: true,
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
      }

    # Base domain setup (includes ESC1, ESC4, ESC6 from shared script)
    dc.vm.provision "shell",
      path: "../../scripts/provision-dc01-step2.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
      }

    # ADCS-specific extras: ESC2, ESC3, ESC7 templates
    dc.vm.provision "shell",
      path: "../../scripts/provision-adcs-extra.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
      }
  end

  # ── WS01: Workstation (domain member, pivot point) ───────────────────────────
  config.vm.define "ws01" do |ws|
    ws.vm.box      = "StefanScherer/windows_10"
    ws.vm.hostname = "WS01"
    ws.vm.network  "private_network", ip: WS1_IP, virtualbox__intnet: "lab-net"

    ws.vm.provider "vmware_desktop" do |v|
      v.vmx["displayName"] = "ADCS-WS01"
      v.memory = 2048
      v.cpus   = 2
    end

    ws.vm.provider "virtualbox" do |vb|
      vb.name   = "ADCS-WS01"
      vb.memory = 2048
      vb.cpus   = 2
    end

    ws.vm.provision "shell",
      path: "../../scripts/provision-ws01.ps1",
      env: {
        "DOMAIN"       => DOMAIN,
        "DOMAIN_SHORT" => DOMAIN_SHORT,
        "ADMIN_PASS"   => DOMAIN_PASS,
        "DC_IP"        => DC_IP,
        "WS_IP"        => WS1_IP,
      }
  end
end
